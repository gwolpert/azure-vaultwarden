{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "388517321202993121"
    }
  },
  "parameters": {
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "The name of the Key Vault"
      }
    },
    "hasAdminToken": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Whether an admin token was provided"
      }
    },
    "adminToken": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "The admin token to store (optional)"
      }
    },
    "databaseUrl": {
      "type": "securestring",
      "metadata": {
        "description": "The database connection string to store"
      }
    }
  },
  "resources": [
    {
      "condition": "[parameters('hasAdminToken')]",
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-02-01",
      "name": "[format('{0}/{1}', parameters('keyVaultName'), 'vaultwarden-admin-token')]",
      "properties": {
        "value": "[parameters('adminToken')]"
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-02-01",
      "name": "[format('{0}/{1}', parameters('keyVaultName'), 'vaultwarden-database-url')]",
      "properties": {
        "value": "[parameters('databaseUrl')]"
      }
    }
  ],
  "outputs": {
    "adminTokenSecretUri": {
      "type": "string",
      "value": "[if(parameters('hasAdminToken'), reference(resourceId('Microsoft.KeyVault/vaults/secrets', parameters('keyVaultName'), 'vaultwarden-admin-token'), '2023-02-01').secretUri, '')]"
    },
    "databaseUrlSecretUri": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.KeyVault/vaults/secrets', parameters('keyVaultName'), 'vaultwarden-database-url'), '2023-02-01').secretUri]"
    }
  }
}